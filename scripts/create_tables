--DDL
-- Drops table if exist and recreates the tables


DROP TABLE IF EXISTS raw_data.crm_cust_info;
CREATE TABLE IF NOT EXISTS raw_data.crm_cust_info(
cst_id INTEGER,
cst_key VARCHAR(50),
cst_firstname VARCHAR(50),
cst_lastname VARCHAR(50),
cst_marital_status VARCHAR(50),
cst_gndr VARCHAR(50),
cst_create_date TIMESTAMP
);

DROP TABLE IF EXISTS raw_data.crm_prd_info;
CREATE TABLE IF NOT EXISTS raw_data.crm_prd_info(
prd_id INTEGER,
prd_key VARCHAR(50),
prd_nm VARCHAR(50),
prd_cost INTEGER,
prd_line VARCHAR(50),
prd_start_dt TIMESTAMP,
prd_end_dt TIMESTAMP
);

DROP TABLE IF EXISTS raw_data.crm_sales_details;
CREATE TABLE IF NOT EXISTS raw_data.crm_sales_details(
sls_ord_num VARCHAR(50),
sls_prd_key VARCHAR(50),
sls_cust_id INTEGER,
sls_order_dt INTEGER,
sls_ship_dt INTEGER,
sls_due_dt INTEGER,
sls_sales INTEGER,
sls_quantity INTEGER,
sls_price INTEGER
);

DROP TABLE IF EXISTS raw_data.erp_cust_az12;
CREATE TABLE IF NOT EXISTS raw_data.erp_cust_az12(
CID VARCHAR(50),
BDATE TIMESTAMP,
GEN VARCHAR(50)
);

DROP TABLE IF EXISTS raw_data.erp_loc_a101;
CREATE TABLE IF NOT EXISTS raw_data.erp_loc_a101(
CID VARCHAR(50),
CNTRY VARCHAR(50)
);
DROP TABLE IF EXISTS raw_data.erp_px_cat_g1v2;
CREATE TABLE IF NOT EXISTS raw_data.erp_px_cat_g1v2(
ID VARCHAR(50),
CAT VARCHAR(50),
SUBCAT VARCHAR(50),
MAINTENANCE VARCHAR(50)
);
