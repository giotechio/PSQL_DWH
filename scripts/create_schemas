/*
Create database and scheemas
Script purpose:
after creating a database in POSTGRES , create three schemas within the database:
'raw_data' - for loading raw data from the dataset, 
'clean_data' - for cleansing data 
and 'business_data' - ready for datamarts or other use in analytics etc.

The script checks if schemas exists and, if not, creates them afterwards.

*/
-- Database: datawarehouse

-- DROP DATABASE IF EXISTS datawarehouse;

CREATE DATABASE datawarehouse
    WITH
    OWNER = postgres
    ENCODING = 'UTF8'
    LC_COLLATE = 'en_GB.UTF-8'
    LC_CTYPE = 'en_GB.UTF-8'
    LOCALE_PROVIDER = 'libc'
    TABLESPACE = pg_default
    CONNECTION LIMIT = -1
    IS_TEMPLATE = False;


-- CREATE SCHEMAS

CREATE SCHEMA IF NOT EXISTS raw_data;
CREATE SCHEMA IF NOT EXISTS clean_data;
CREATE SCHEMA IF NOT EXISTS business_data;


